rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function role() {
      return hasUserDoc() ? get(userPath(request.auth.uid)).data.role : null;
    }

    function isAdminLike() {
      return role() in ['admin', 'manager'];
    }

    function canStaffOrder() {
      return role() in ['staff', 'manager', 'admin'];
    }

    function canBoard() {
      return role() in ['hostess', 'cashier', 'manager', 'admin'];
    }

    function bootstrapDone() {
      return exists(/databases/$(database)/documents/app_settings/main) &&
        get(/databases/$(database)/documents/app_settings/main).data.bootstrapComplete == true;
    }

    match /menu_categories/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdminLike();
    }

    match /menu_items/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdminLike();
    }

    match /orders/{orderId} {
      allow create: if canStaffOrder() &&
        request.resource.data.createdByUid == request.auth.uid;

      allow read: if canBoard() || isAdminLike() ||
        (signedIn() && resource.data.createdByUid == request.auth.uid);

      allow update, delete: if canBoard() || isAdminLike();
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdminLike());

      allow create: if
        (signedIn() &&
         request.auth.uid == uid &&
         !bootstrapDone() &&
         request.resource.data.role == 'admin')
        || isAdminLike();

      allow update, delete: if isAdminLike();
    }

    match /app_settings/{docId} {
      allow read: if signedIn();
      allow create, update: if isAdminLike() ||
        (signedIn() && !bootstrapDone() && docId == 'main');
      allow delete: if false;
    }
  }
}
